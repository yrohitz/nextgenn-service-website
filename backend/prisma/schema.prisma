generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model CallbackRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  service   String
  message   String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
}